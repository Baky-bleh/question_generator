{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CourseManifest",
  "type": "object",
  "required": ["course_slug", "language_from", "language_to", "title", "content_version", "units"],
  "additionalProperties": false,
  "properties": {
    "course_slug": { "type": "string", "minLength": 1 },
    "language_from": { "type": "string", "minLength": 2, "maxLength": 10 },
    "language_to": { "type": "string", "minLength": 2, "maxLength": 10 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "content_version": { "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+$" },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["order", "title", "lessons"],
        "additionalProperties": false,
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "lessons": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "order", "title", "type", "exercise_count", "estimated_minutes"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "order": { "type": "integer", "minimum": 1 },
                "title": { "type": "string", "minLength": 1 },
                "type": { "enum": ["standard", "review", "checkpoint"] },
                "exercise_count": { "type": "integer", "minimum": 1 },
                "estimated_minutes": { "type": "integer", "minimum": 1 }
              }
            },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    }
  }
}
